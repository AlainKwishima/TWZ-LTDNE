PORT=4007
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/notification_service_db
JWT_SECRET=change-this-to-a-long-secure-secret-min-32-chars
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Brevo transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=TWZ LTD
EMAIL_ENABLED=true

# SMS (optional — default stub)
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Expiry alert cron (default: 08:00 and 20:00 daily)
CRON_SCHEDULE=0 8,20 * * *
EXPIRY_RUN_ON_STARTUP=true
