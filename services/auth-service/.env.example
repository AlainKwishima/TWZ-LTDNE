PORT=4001
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/auth_service_db
JWT_SECRET=change-this-to-a-long-secure-secret-min-32-chars
OTP_SECRET=change-this-to-another-secure-secret-min-32-chars
JWT_EXPIRES_IN=24h

# Brevo transactional email (OTP, password reset)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=TWZ LTD
EMAIL_ENABLED=true
FRONTEND_URL=http://localhost:5173
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# OTP is sent once after signup (email verification). Sign-in uses password only unless this is true:
LOGIN_REQUIRES_OTP=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
