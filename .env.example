# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
# Use 127.0.0.1 (not localhost) on Windows if Docker Postgres maps to 5433 — avoids IPv6 hitting a different server
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Database URLs (local development)
AUTH_DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5433/auth_service_db
ASSET_DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5433/asset_service_db
SERVICE_REQUEST_DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5433/service_request_service_db
NOTIFICATION_DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5433/notification_service_db
REPORTING_DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5433/reporting_service_db

# Security
JWT_SECRET=change-this-to-a-long-secure-secret-min-32-chars
OTP_SECRET=change-this-to-another-secure-secret-min-32-chars
JWT_EXPIRES_IN=24h
LOGIN_REQUIRES_OTP=false

# Email — Brevo (transactional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=FEMS
EMAIL_ENABLED=true
BREVO_RETRY_MAX_ATTEMPTS=10
BREVO_RETRY_BASE_DELAY_MS=1000
EMAIL_DEV_FALLBACK=true
BREVO_TEST_RECIPIENT=

# SMS (optional)
SMS_PROVIDER=

# Message Broker
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Service URLs (local development)
AUTH_SERVICE_URL=http://localhost:4001
ASSET_SERVICE_URL=http://localhost:4005
SERVICE_REQUEST_SERVICE_URL=http://localhost:4006
NOTIFICATION_SERVICE_URL=http://localhost:4007
REPORTING_SERVICE_URL=http://localhost:4008

# API Gateway & Frontend
API_GATEWAY_PORT=4000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:4000/api
NODE_ENV=development

# Optional: demo asset seed (user@fems.local id after auth seed)
# Asset seed links demo extinguisher to user@fems.local (auth DB must be reachable)
# DEMO_CUSTOMER_ID=
# DEMO_PORTAL_EMAIL=user@fems.local

# After editing .env: node scripts/sync-service-env.mjs
# Verify: npm run verify:config  |  Test email: npm run test:email
